# URL del webhook de n8n que recibe los correos de suscripción.
# Configúrala en Dokploy (Environment) con la URL de producción de tu webhook.
# La app envía un POST con JSON: { email, source, userAgent }
# Si no está definida, el sitio funciona pero las suscripciones responden 503.
N8N_SUBSCRIBE_WEBHOOK_URL=https://n8n.tu-dominio.com/webhook/xxxxxxxx
